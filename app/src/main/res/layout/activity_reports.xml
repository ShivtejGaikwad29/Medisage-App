<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F7FA">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Medical Reports"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_marginBottom="6dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload and manage your health documents"
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:layout_marginBottom="18dp" />

    <!-- Upload Button -->
    <Button
        android:id="@+id/btnSelectReport"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Upload New Report"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"
        android:elevation="5dp"
        android:layout_marginBottom="12dp" />

    <!-- Camera Button -->
    <Button
        android:id="@+id/btnCameraReport"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="Take Photo of Report"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textSize="16sp"
        android:backgroundTint="#16A34A"
        android:textColor="#FFFFFF"
        android:elevation="5dp"
        android:layout_marginBottom="16dp" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/uploadProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- Section Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Uploaded Reports"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginBottom="10dp" />

    <!-- Reports List Container -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        android:backgroundTint="#FFFFFF">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/reportsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp" />

    </androidx.cardview.widget.CardView>

</LinearLayout>